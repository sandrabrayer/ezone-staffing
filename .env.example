# --- Required ---

# Apps Script Web App URL (the one ending in /exec)
APPS_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_ME/exec

# Shared secret. MUST match the SHARED_SECRET set in the Apps Script
# Script Properties. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SHARED_SECRET=REPLACE_ME_WITH_LONG_RANDOM_HEX

# Moran's PIN (string, 4–12 chars; use digits only for keypad UX)
MORAN_PIN=REPLACE_ME

# Secret used to sign session tokens. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_ME_WITH_LONG_RANDOM_HEX

# --- Optional ---

# Port (Railway sets this automatically)
PORT=3000

# Session lifetime in days (default 7)
SESSION_DAYS=7
